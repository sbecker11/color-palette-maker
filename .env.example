# All env vars live at repo root. Server, scripts, and Vite (client) read this file.
# Copy to .env and edit as needed. See docs/REPLICATE-PORTS-CONFIG.md for ports.

# --- Ports (use different values per app to run multiple instances in parallel) ---
EXPRESS_PORT=3000
# Dedicated Vite dev port (avoid collisions with other local apps on 5173/5174).
VITE_DEV_PORT=5188
# VITE_API_PORT=3000

# --- Server / region detection ---
# DETECT_REGIONS_PYTHON=/path/to/python

# --- Palette luminance (0-255). Excludes near-black/white from extraction. ---
MIN_LUMINANCE_THRESHOLD=25
MAX_LUMINANCE_THRESHOLD=185

# --- Client (Vite): region boundary and highlight on hover ---
# VITE_REGION_BOUNDARY_STROKE_WIDTH=1
# VITE_REGION_BOUNDARY_STROKE_COLOR=rgba(50, 120, 200, 0.9)
VITE_HIGHLIGHT_REGION_ON_ROLLOVER=true
# VITE_REGION_HIGHLIGHT_STROKE_WIDTH=5
# VITE_REGION_HIGHLIGHT_STROKE_COLOR=rgba(80, 160, 255, 1)
# VITE_REGION_HIGHLIGHT_FILL=transparent

# --- Optional: S3 for palette source images (file + URL uploads) ---
# When S3_IMAGES_BUCKET is set and a region is available (AWS_REGION or region in ~/.aws/config [default] or AWS_PROFILE),
# each processed image is also stored in S3. Keys can live in ~/.aws/credentials [default] like the AWS CLI.
# Metadata gains s3Key + imagePublicUrl; the UI and exports use the public URL when present.
# Permission model: public read-only (GetObject on prefix/*) + IAM read-write for the app — see docs/S3-STORAGE.md
# S3_IMAGES_BUCKET=your-bucket-name
# Optional overrides (omit if using ~/.aws/config region + ~/.aws/credentials keys):
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Optional: object key prefix (default images)
# S3_IMAGES_PREFIX=images
# Optional: palette list JSONL in the same bucket (default metadata/color_palettes.jsonl). Bucket policy: public GetObject on this object (read-only for consumers), same idea as images/* — see docs/S3-STORAGE.md / create-s3-palette-bucket.sh
# S3_PALETTES_JSONL_KEY=metadata/color_palettes.jsonl
# Optional: public base URL if using CloudFront or custom domain (no trailing slash)
# S3_PUBLIC_URL_BASE=https://d111111abcdef8.cloudfront.net
# Bucket must allow public GetObject (or use a policy on prefix images/*) for imagePublicUrl to work in the browser.
# For canvas color sampling, add a CORS rule on the bucket allowing GET from your app origin.

# --- color-palette-utils-ts: public palette catalog URL (integration tests, consumers) ---
# S3_COLOR_PALETTES_JSON_URL=https://sbecker11-color-palette-images.s3.us-west-1.amazonaws.com/metadata/color_palettes.jsonl

# --- utils (color contrast): swatch highlight percentage ---
# Python reads from env; client passes to utils when calling getHighlightColor.
# VITE_SWATCH_HIGHLIGHT_PERCENTAGE=135
