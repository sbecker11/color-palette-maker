# All env vars live at repo root. Server, scripts, and Vite (client) read this file.
# Copy to .env and edit as needed. See docs/REPLICATE-PORTS-CONFIG.md for ports.

# --- Ports (use different values per app to run multiple instances in parallel) ---
EXPRESS_PORT=3000
# VITE_DEV_PORT=5173
# VITE_API_PORT=3000

# --- Server / region detection ---
# DETECT_REGIONS_PYTHON=/path/to/python

# --- Palette luminance (0-255). Excludes near-black/white from extraction. ---
MIN_LUMINANCE_THRESHOLD=25
MAX_LUMINANCE_THRESHOLD=185

# --- Client (Vite): region boundary and highlight on hover ---
# VITE_REGION_BOUNDARY_STROKE_WIDTH=1
# VITE_REGION_BOUNDARY_STROKE_COLOR=rgba(50, 120, 200, 0.9)
VITE_HIGHLIGHT_REGION_ON_ROLLOVER=true
# VITE_REGION_HIGHLIGHT_STROKE_WIDTH=5
# VITE_REGION_HIGHLIGHT_STROKE_COLOR=rgba(80, 160, 255, 1)
# VITE_REGION_HIGHLIGHT_FILL=transparent

# --- palette-utils: swatch highlight percentage. Used exclusively by palette-utils. ---
# Python reads from env; client passes to palette-utils when calling getHighlightColor.
# VITE_SWATCH_HIGHLIGHT_PERCENTAGE=135
